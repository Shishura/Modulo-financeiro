generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===================== Autenticação (Better Auth) =====================

enum Role {
  ADMIN
  FUNCIONARIO
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  role          Role     @default(FUNCIONARIO)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions  Session[]
  accounts  Account[]

  despesasCriadas        Despesa[]            @relation("DespesaCriadaPor")
  despesasPagamentos     DespesaPagamento[]
  despesasHistorico      DespesaHistorico[]
  recebimentosCriados    Recebimento[]        @relation("RecebimentoCriadoPor")
  recebimentosBaixas     RecebimentoBaixa[]
  recebimentosHistorico  RecebimentoHistorico[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ===================== Módulo Financeiro =====================

// Status comum ao ciclo de vida de Despesas e Recebimentos.
// PENDENTE -> PARCIAL -> PAGO (nunca há exclusão física; cancelamento = CANCELADO)
enum StatusTitulo {
  PENDENTE
  PARCIAL
  PAGO
  CANCELADO
}

// ---------- Contas a Pagar (RF-FM-001 a RF-FM-005) ----------

model Despesa {
  id             String       @id @default(uuid())
  descricao      String
  fornecedor     String
  valor          Decimal      @db.Decimal(12, 2)
  valorPago      Decimal      @default(0) @db.Decimal(12, 2)
  dataVencimento DateTime     @db.Date
  status         StatusTitulo @default(PENDENTE)

  criadoPorId String
  criadoPor   User   @relation("DespesaCriadaPor", fields: [criadoPorId], references: [id])

  pagamentos DespesaPagamento[]
  historico  DespesaHistorico[]

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@map("despesa")
}

model DespesaPagamento {
  id        String   @id @default(uuid())
  despesaId String
  despesa   Despesa  @relation(fields: [despesaId], references: [id])
  valor     Decimal  @db.Decimal(12, 2)
  pagoEm    DateTime @db.Timestamptz()

  registradoPorId String
  registradoPor   User   @relation(fields: [registradoPorId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz()

  @@map("despesa_pagamento")
}

model DespesaHistorico {
  id             String        @id @default(uuid())
  despesaId      String
  despesa        Despesa       @relation(fields: [despesaId], references: [id])
  acao           String // CRIADO, ATUALIZADO, PAGAMENTO_REGISTRADO, CANCELADO
  statusAnterior StatusTitulo?
  statusNovo     StatusTitulo?
  detalhes       String?

  alteradoPorId String
  alteradoPor   User   @relation(fields: [alteradoPorId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz()

  @@map("despesa_historico")
}

// ---------- Contas a Receber (RF-FM-006 a RF-FM-010) ----------

model Recebimento {
  id             String       @id @default(uuid())
  descricao      String
  cliente        String
  valor          Decimal      @db.Decimal(12, 2)
  valorRecebido  Decimal      @default(0) @db.Decimal(12, 2)
  dataVencimento DateTime     @db.Date
  status         StatusTitulo @default(PENDENTE)

  criadoPorId String
  criadoPor   User   @relation("RecebimentoCriadoPor", fields: [criadoPorId], references: [id])

  baixas    RecebimentoBaixa[]
  historico RecebimentoHistorico[]

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@map("recebimento")
}

model RecebimentoBaixa {
  id            String      @id @default(uuid())
  recebimentoId String
  recebimento   Recebimento @relation(fields: [recebimentoId], references: [id])
  valor         Decimal     @db.Decimal(12, 2)
  recebidoEm    DateTime    @db.Timestamptz()

  registradoPorId String
  registradoPor   User   @relation(fields: [registradoPorId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz()

  @@map("recebimento_baixa")
}

model RecebimentoHistorico {
  id             String        @id @default(uuid())
  recebimentoId  String
  recebimento    Recebimento   @relation(fields: [recebimentoId], references: [id])
  acao           String // CRIADO, ATUALIZADO, BAIXA_REGISTRADA, CANCELADO
  statusAnterior StatusTitulo?
  statusNovo     StatusTitulo?
  detalhes       String?

  alteradoPorId String
  alteradoPor   User   @relation(fields: [alteradoPorId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz()

  @@map("recebimento_historico")
}
